    "build:husky": "tsc --project tsconfig.json  --outDir ./dist && rm -rf ./dist",
    "knip": "knip"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "knip": "^6.16.1",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "package-json": "npm:package-json@latest",
    "esbuild": "npm:esbuild@latest",
    "parse-url": "npm:parsed-url@latest",
    "gry": "npm:gry@latest"
  }
}
