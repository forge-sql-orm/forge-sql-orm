{
  "name": "jira-global-page-custom-ui",
  "version": "1.1.4",
  "main": "index.js",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@forge/resolver": "1.8.0",
    "@forge/sql": "^3.0.25",
    "drizzle-orm": "^0.45.2",
    "forge-sql-orm": "^2.2.0",
    "minisearch": "^7.2.0"
  },
  "scripts": {
    "build:ci": "tsc --target esnext --project tsconfig.json --ignoreDeprecations 6.0 --outDir dist && rm -rf dist",
