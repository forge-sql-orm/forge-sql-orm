{
  "name": "jira-global-page-custom-ui",
  "version": "1.1.4",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@forge/resolver": "2.0.0",
    "@forge/sql": "^4.0.0",
    "drizzle-orm": "^0.45.2",
    "forge-sql-orm": "2.2.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "drizzle-kit": "^0.31.10",
    "forge-sql-orm-cli": "^2.2.3",
    "knip": "^6.20.0",
    "mysql2": "^3.22.5",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "models:create": "forge-sql-orm-cli generate:model --output src/entities",
    "migration:create": "forge-sql-orm-cli migrations:create --force",
    "migration:update": "forge-sql-orm-cli migrations:update",
    "migration:drop": "forge-sql-orm-cli migrations:drop",
    "build:ci": "tsc --target esnext --project tsconfig.json --ignoreDeprecations 6.0 --outDir dist && rm -rf dist",
    "forge:debug": "forge tunnel -d -f index.handler",
    "forge:debug:dropMigrations": "forge tunnel -d -f dropMigrations",
    "knip": "knip"
  },
  "overrides": {
    "esbuild": "npm:esbuild@latest",
    "parse-url": "npm:parsed-url@latest",
    "gry": "npm:gry@latest"
  }
}
