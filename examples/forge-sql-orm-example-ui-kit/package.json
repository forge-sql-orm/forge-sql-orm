{
  "name": "jira-global-page-ui-kit",
  "version": "1.1.33",
  "main": "index.js",
  "license": "MIT",
  "private": true,
  "scripts": {
    "lint": "eslint src",
    "knip": "knip",
    "models:create": "forge-sql-orm-cli generate:model --output src/database/entities --saveEnv",
    "migration:create": "forge-sql-orm-cli migrations:create --force --output src/database/migration",
    "migration:update": "forge-sql-orm-cli migrations:update --entitiesPath src/database/entities --output src/migration",
    "build:ci": "tsc --target esnext --project tsconfig.json --ignoreDeprecations 6.0 --outDir dist && rm -rf dist"
  },
  "devDependencies": {
    "eslint-plugin-react-hooks": "^7.1.1",
    "forge-sql-orm-cli": "^2.2.3",
    "knip": "^6.22.0"
  },
  "dependencies": {
    "@forge/bridge": "6.0.0",
    "@forge/react": "12.0.0",
    "@forge/resolver": "2.0.0",
    "@forge/sql": "^4.0.0",
    "drizzle-orm": "^0.45.2",
    "forge-sql-orm": "^2.2.3",
    "react": "^18.2.0"
  },
  "overrides": {
    "@compiled/react": "latest"
  }
}
