    "@types/node": "^25.5.2",
    "knip": "^6.3.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "package-json": "npm:package-json@latest",
    "esbuild": "npm:esbuild@latest",
    "parse-url": "npm:parsed-url@latest",
    "gry": "npm:gry@latest"
  }
