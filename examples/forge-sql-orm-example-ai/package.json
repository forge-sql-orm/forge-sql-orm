{
  "name": "jira-global-page-custom-ui",
  "version": "1.1.4",
  "main": "index.js",
  "license": "MIT",
  "private": true,
  "dependencies": {
    "@forge/resolver": "1.7.1",
    "@forge/sql": "^3.0.21",
    "drizzle-orm": "^0.45.2",
    "forge-sql-orm": "^2.1.26"
  },
  "scripts": {
    "build:ci": "tsc --target esnext --project tsconfig.json  --outDir dist && rm -rf dist",
